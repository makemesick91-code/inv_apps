APP_NAME="Klinik Inventori"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.__DOMAIN__

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=klinik_inventori
DB_USERNAME=klinik
DB_PASSWORD=__CHANGE_ME__

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.__DOMAIN__
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

SANCTUM_STATEFUL_DOMAINS=__DOMAIN__,www.__DOMAIN__
SANCTUM_TOKEN_EXPIRATION=20160

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@__DOMAIN__"
MAIL_FROM_NAME="${APP_NAME}"
